<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:padding="16dp"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <EditText android:id="@+id/edtTitle" android:hint="Tên bài hát" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/edtDate" android:hint="Ngày ra đĩa (yyyy-MM-dd)" android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <Button android:id="@+id/btnSave" android:text="Lưu" android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>
